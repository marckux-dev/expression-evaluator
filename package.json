{
  "name": "@marckux-dev/expression-evaluator",
  "version": "0.2.0",
  "description": "Minimal, dependency-free and extensible math expression evaluator (infix and RPN). Teach it your own domain operators.",
  "keywords": [
    "math",
    "expression",
    "evaluator",
    "parser",
    "calculator",
    "rpn",
    "shunting-yard",
    "formula"
  ],
  "author": "marckux",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marckux-dev/expression-evaluator.git"
  },
  "homepage": "https://github.com/marckux-dev/expression-evaluator#readme",
  "bugs": {
    "url": "https://github.com/marckux-dev/expression-evaluator/issues"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm test && npm run build"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^22.5.0",
    "jest": "^29.7.0",
    "prettier": "^3.9.4",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typescript": "^5.5.4"
  }
}
